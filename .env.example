# Empty sample file. Put real values in ~/secrets/us-fashion/.env or OS
# environment variables, not in this repository.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
HF_TOKEN=

# Optional: require users to paste a provider key in the UI instead of using
# local environment fallback values. Set to 1 for stricter demo/session hygiene.
# UFPS_REQUIRE_USER_PROVIDER_KEY=1

# Optional: URL prefix where `docs/docs.html` is served locally
# (sidebar links in Streamlit). Default http://127.0.0.1:8510 when unset.
# UFPS_STATIC_DOCS_BASE=http://127.0.0.1:8510
